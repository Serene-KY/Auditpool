{
  "name": "api",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "migrate": "ts-node --transpile-only src/migrate.ts",
    "seed": "ts-node --transpile-only src/seed.ts",
    "dev": "pnpm run migrate && ts-node-dev --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "test": "vitest run",
    "test:watch": "vitest",
    "lint": "eslint src"
  },
  "dependencies": {
    "@fastify/cors": "^11.2.0",
    "dotenv": "^17.3.1",
    "fastify": "^5.7.4",
    "groq-sdk": "^0.37.0",
    "pg": "^8.19.0",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@types/pg": "^8.18.0",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "typescript": "^5.9.3",
    "vitest": "^3.2.4"
  }
}
